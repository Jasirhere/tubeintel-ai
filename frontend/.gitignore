@'
# Environment variables and secrets
.env
.env.*
!.env.example
frontend/.env.local
frontend/.env.*
!frontend/.env.example

# Python
venv/
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Generated backend data
backend/data/runs/*
!backend/data/runs/.gitkeep
backend/data/vectors/*
!backend/data/vectors/.gitkeep
backend/outputs/
backend/chroma_db/

# Next.js
frontend/node_modules/
frontend/.next/
frontend/out/

# Logs and temporary files
*.log
*.tmp
*.zip

# Editors and operating systems
.vscode/
.idea/
.DS_Store
Thumbs.db
'@ | Set-Content ".\.gitignore" -Encoding UTF8